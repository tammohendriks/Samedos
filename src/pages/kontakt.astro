---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt — Samedos Arbeitsmedizin Bremen"
  description="Kontaktieren Sie Samedos: Timmersloher Str. 82, 28215 Bremen. Tel: 0421 63997761. Mo–Fr 08–15 Uhr. Auch außerhalb der Öffnungszeiten erreichbar."
>

  <section class="pt-20 pb-16" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5" data-animate>
        Kontakt
      </p>
      <h1 class="text-[clamp(2rem,4vw,3rem)] text-white" data-animate data-delay="1">Wir sind für Sie da</h1>
      <p class="text-white/75 text-[1.1rem] mt-4 max-w-xl" data-animate data-delay="2">
        Rufen Sie an, schreiben Sie uns oder nutzen Sie das Formular — wir antworten schnell.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-16">

        <!-- Kontaktdaten -->
        <div class="space-y-8" data-animate>
          <div>
            <h2 class="text-[1.4rem] mb-6">Kontaktdaten</h2>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <span class="w-10 h-10 bg-mint-soft rounded-xl grid place-items-center text-mint shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                    <path d="M12 21s-7-5-7-11a7 7 0 0114 0c0 6-7 11-7 11z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <div>
                  <p class="font-medium text-navy">Adresse</p>
                  <p class="text-muted text-[0.95rem]">Timmersloher Straße 82<br />28215 Bremen</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-10 h-10 bg-mint-soft rounded-xl grid place-items-center text-mint shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                  </svg>
                </span>
                <div>
                  <p class="font-medium text-navy">Telefon</p>
                  <a href="tel:042163997761" class="text-muted text-[0.95rem] hover:text-mint transition-colors">0421 63997761</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-10 h-10 bg-mint-soft rounded-xl grid place-items-center text-mint shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                  </svg>
                </span>
                <div>
                  <p class="font-medium text-navy">E-Mail</p>
                  <a href="mailto:info@samedos.de" class="text-muted text-[0.95rem] hover:text-mint transition-colors">info@samedos.de</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-10 h-10 bg-mint-soft rounded-xl grid place-items-center text-mint shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                <div>
                  <p class="font-medium text-navy">Öffnungszeiten</p>
                  <p class="text-muted text-[0.95rem]">Mo – Fr: 08:00 – 15:00 Uhr</p>
                  <p class="text-mint text-[0.9rem] font-medium mt-1">Auch außerhalb erreichbar</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- Kontaktformular -->
        <div class="bg-white border border-border rounded-2xl p-8" data-animate data-delay="2">
          <h2 class="text-[1.4rem] mb-6">Nachricht senden</h2>

          <!-- Erfolgsmeldung -->
          <div id="form-success" class="hidden text-center py-10">
            <div class="w-14 h-14 bg-mint-soft rounded-full grid place-items-center mx-auto mb-4">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-7 h-7 text-mint">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </div>
            <h3 class="text-[1.2rem] mb-2">Nachricht gesendet!</h3>
            <p class="text-muted text-[0.95rem]">Vielen Dank — wir melden uns so schnell wie möglich bei Ihnen.</p>
          </div>

          <!-- Fehlermeldung -->
          <div id="form-error" class="hidden mb-5 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-[0.9rem]">
            Es ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut oder schreiben Sie uns direkt an <a href="mailto:info@samedos.de" class="underline">info@samedos.de</a>.
          </div>

          <form id="kontakt-form" method="POST" action="/api/kontakt" class="space-y-5">
            <!-- Honeypot -->
            <input type="text" name="_honeypot" class="hidden" tabindex="-1" autocomplete="off" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="vorname" class="block text-[0.9rem] font-medium text-navy mb-1.5">Vorname *</label>
                <input
                  id="vorname" name="vorname" type="text" required
                  class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors"
                />
              </div>
              <div>
                <label for="nachname" class="block text-[0.9rem] font-medium text-navy mb-1.5">Nachname *</label>
                <input
                  id="nachname" name="nachname" type="text" required
                  class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-[0.9rem] font-medium text-navy mb-1.5">E-Mail *</label>
              <input
                id="email" name="email" type="email" required
                class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="unternehmen" class="block text-[0.9rem] font-medium text-navy mb-1.5">Unternehmen</label>
                <input
                  id="unternehmen" name="unternehmen" type="text"
                  class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors"
                />
              </div>
              <div>
                <label for="telefon" class="block text-[0.9rem] font-medium text-navy mb-1.5">Telefon</label>
                <input
                  id="telefon" name="telefon" type="tel"
                  class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="betreff" class="block text-[0.9rem] font-medium text-navy mb-1.5">Betreff *</label>
              <select
                id="betreff" name="betreff" required
                class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors bg-white"
              >
                <option value="">Bitte wählen…</option>
                <option value="Terminanfrage">Terminanfrage</option>
                <option value="Allgemeine Frage">Allgemeine Frage</option>
                <option value="Sonstiges">Sonstiges</option>
              </select>
            </div>

            <div>
              <label for="nachricht" class="block text-[0.9rem] font-medium text-navy mb-1.5">Nachricht *</label>
              <textarea
                id="nachricht" name="nachricht" required rows="5"
                class="w-full border border-border rounded-xl px-4 py-3 text-[0.95rem] focus:outline-none focus:border-mint transition-colors resize-none"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                id="dsgvo" name="dsgvo" type="checkbox" required
                class="mt-1 w-4 h-4 accent-mint shrink-0"
              />
              <label for="dsgvo" class="text-[0.88rem] text-muted">
                Ich habe die <a href="/datenschutz" class="text-navy underline hover:text-mint">Datenschutzerklärung</a> gelesen
                und willige in die Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage ein. *
              </label>
            </div>

            <button
              id="submit-btn"
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 px-[22px] py-3.5 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)] disabled:opacity-60 disabled:pointer-events-none"
            >
              <span id="submit-label">Nachricht senden →</span>
              <svg id="submit-spinner" class="hidden animate-spin w-4 h-4" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="32" stroke-dashoffset="12"/>
              </svg>
            </button>

            <p class="text-muted text-[0.82rem] text-center">
              * Pflichtfelder. Formulardaten werden nur zur Bearbeitung Ihrer Anfrage verwendet.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Anfahrt -->
  <section class="py-16 bg-bg-soft" id="anfahrt">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-8" data-animate>
        <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
          Anfahrt
        </p>
        <h2>So finden Sie uns</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-8 items-start" data-animate data-delay="1">

        <!-- Anfahrtsinfos -->
        <div class="space-y-6">
          <div class="bg-white border border-border rounded-2xl p-6">
            <h3 class="text-[1.05rem] mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-mint-soft rounded-lg grid place-items-center text-mint shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                  <path d="M12 21s-7-5-7-11a7 7 0 0114 0c0 6-7 11-7 11z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              Adresse
            </h3>
            <p class="text-muted text-[0.95rem]">
              Timmersloher Straße 82<br />
              28215 Bremen (Findorff)
            </p>
          </div>

          <div class="bg-white border border-border rounded-2xl p-6">
            <h3 class="text-[1.05rem] mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-mint-soft rounded-lg grid place-items-center text-mint shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                  <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
              </span>
              Mit dem ÖPNV
            </h3>
            <p class="text-muted text-[0.95rem]">
              Haltestelle <strong class="text-navy">Hemmstraße</strong><br />
              Linien <strong class="text-navy">25, 26, 28</strong><br />
              ab Hauptbahnhof
            </p>
          </div>

          <div class="bg-white border border-border rounded-2xl p-6">
            <h3 class="text-[1.05rem] mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-mint-soft rounded-lg grid place-items-center text-mint shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                  <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="16" r="1"/><circle cx="20" cy="16" r="1"/>
                </svg>
              </span>
              Mit dem PKW
            </h3>
            <p class="text-muted text-[0.95rem]">
              Parken in der Timmersloher Straße<br />
              oder umliegenden Nebenstraßen.<br />
              Keine reservierten Stellplätze.
            </p>
          </div>
        </div>

        <!-- Google Maps Iframe -->
        <div class="rounded-2xl overflow-hidden border border-border shadow-sm h-[420px]">
          <iframe
            src="https://maps.google.com/maps?q=Timmersloher+Stra%C3%9Fe+82,+28215+Bremen&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Samedos Standort auf Google Maps"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('kontakt-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const label = document.getElementById('submit-label')!;
  const spinner = document.getElementById('submit-spinner')!;
  const success = document.getElementById('form-success')!;
  const errorBox = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    label.textContent = 'Wird gesendet…';
    spinner.classList.remove('hidden');
    errorBox.classList.add('hidden');

    try {
      const res = await fetch('/api/kontakt', { method: 'POST', body: new FormData(form) });
      const json = await res.json();

      if (json.ok) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
      } else {
        throw new Error();
      }
    } catch {
      errorBox.classList.remove('hidden');
      btn.disabled = false;
      label.textContent = 'Nachricht senden →';
      spinner.classList.add('hidden');
    }
  });
</script>
