---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPriceLists } from '../sanity/client';

const priceLists = await getPriceLists();
const pdfFor = (cat: string) => priceLists.find(p => p.category === cat)?.pdf?.asset?.url ?? null;

const tabs = [
  { id: 'g-untersuchungen', label: 'G-Untersuchungen' },
  { id: 'sonderuntersuchungen', label: 'Sonderuntersuchungen' },
  { id: 'labor', label: 'Labor' },
  { id: 'impfungen', label: 'Impfungen' },
];
---

<BaseLayout
  title="Preise — Samedos Arbeitsmedizin Bremen"
  description="Transparente Preise für arbeitsmedizinische Untersuchungen bei Samedos: G-Untersuchungen, Labor, Impfungen und Sonderuntersuchungen in Bremen."
>

  <section class="pt-20 pb-16" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5" data-animate>
        Unsere Preise
      </p>
      <h1 class="text-[clamp(2rem,4vw,3rem)] text-white" data-animate data-delay="1">Transparente Preisübersicht</h1>
      <p class="text-white/75 text-[1.1rem] mt-4 max-w-xl" data-animate data-delay="2">
        Alle Preise zzgl. der gesetzlichen Mehrwertsteuer. Bei Fragen stehen wir gerne zur Verfügung.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-[1200px] mx-auto px-6">

      <!-- Tab navigation -->
      <div class="flex flex-wrap gap-2 mb-10 border-b border-border pb-1" role="tablist" data-animate>
        {tabs.map((tab, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${tab.id}`}
            id={`tab-${tab.id}`}
            class={`tab-btn px-5 py-2.5 rounded-t-xl font-medium text-[0.95rem] transition-all border-b-2 -mb-[1px] ${
              i === 0
                ? 'border-mint text-navy bg-mint-soft'
                : 'border-transparent text-muted hover:text-navy hover:bg-bg-soft'
            }`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {[
        { id: 'g-untersuchungen',    heading: 'G-Untersuchungen',           desc: 'Arbeitsmedizinische Vorsorge- und Eignungsuntersuchungen gemäß DGUV Grundsätzen.' },
        { id: 'sonderuntersuchungen', heading: 'Sonderuntersuchungen',       desc: 'Spezielle arbeitsmedizinische Untersuchungen auf Einzelanfrage.' },
        { id: 'labor',               heading: 'Laborleistungen',             desc: 'Labordiagnostik im Rahmen arbeitsmedizinischer Vorsorge.' },
        { id: 'impfungen',           heading: 'Impfungen',                   desc: 'Schutzimpfungen im betriebsärztlichen Kontext.' },
      ].map((panel, i) => {
        const pdf = pdfFor(panel.id);
        return (
          <div id={`panel-${panel.id}`} role="tabpanel" aria-labelledby={`tab-${panel.id}`} hidden={i !== 0 ? true : undefined}>
            <div class="mb-6" data-animate>
              <h2 class="text-[1.4rem] mb-2">{panel.heading}</h2>
              <p class="text-muted">{panel.desc}</p>
            </div>
            <div class="bg-white border border-border rounded-2xl overflow-hidden" data-animate data-delay="1">
              <div class="p-8 text-center text-muted">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="mx-auto mb-4 text-mint opacity-60">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>
                </svg>
                {pdf ? (
                  <>
                    <p class="font-medium text-navy mb-2">Preisliste verfügbar</p>
                    <a
                      href={pdf}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-2 inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-mint text-navy font-bold text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(100,197,174,.35)]"
                    >
                      PDF herunterladen ↓
                    </a>
                  </>
                ) : (
                  <>
                    <p class="font-medium text-navy mb-2">Preisliste auf Anfrage</p>
                    <p class="text-[0.95rem] mb-5">Die vollständige Preisliste stellen wir gerne auf Anfrage zur Verfügung.</p>
                    <a
                      href={`mailto:info@samedos.de?subject=Preisanfrage ${panel.heading}`}
                      class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
                    >
                      Preisliste anfordern →
                    </a>
                  </>
                )}
              </div>
            </div>
          </div>
        );
      })}

    </div>
  </section>

</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = tab.getAttribute('aria-controls')!;

      tabs.forEach((t) => {
        t.setAttribute('aria-selected', 'false');
        t.classList.remove('border-mint', 'text-navy', 'bg-mint-soft');
        t.classList.add('border-transparent', 'text-muted');
      });

      panels.forEach((p) => p.setAttribute('hidden', ''));

      tab.setAttribute('aria-selected', 'true');
      tab.classList.add('border-mint', 'text-navy', 'bg-mint-soft');
      tab.classList.remove('border-transparent', 'text-muted');

      const panel = document.getElementById(targetId)!;
      panel.removeAttribute('hidden');

      panel.querySelectorAll('[data-animate]').forEach((el) => {
        el.classList.remove('in-view');
        setTimeout(() => el.classList.add('in-view'), 50);
      });
    });
  });

  // Trigger animation for visible panel on load
  document.querySelectorAll('[role="tabpanel"]:not([hidden]) [data-animate]').forEach((el) => {
    el.classList.add('in-view');
  });
</script>
