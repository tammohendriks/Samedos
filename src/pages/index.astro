---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import ValueCard from '../components/ValueCard.astro';
import CtaBand from '../components/CtaBand.astro';

const values = [
  {
    title: 'Prävention',
    description: 'Wir setzen auf frühzeitige Vorsorge und individuelle Beratung, damit Risiken gar nicht erst entstehen.',
    iconPath: 'M12 2L4 7v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V7l-8-5z',
  },
  {
    title: 'Verlässlichkeit',
    description: 'Als erfahrener Partner stehen wir Unternehmen dauerhaft zur Seite — von gesetzlichen Untersuchungen bis zu individuellen Lösungen.',
    iconPath: 'M20 6L9 17l-5-5',
  },
  {
    title: 'Nachhaltigkeit',
    description: 'Gesunde Mitarbeitende sind die Grundlage für nachhaltigen Unternehmenserfolg — dafür arbeiten wir jeden Tag.',
    iconPath: 'M12 2v20M2 12h20',
  },
  {
    title: 'Vertrauen',
    description: 'Persönliche Betreuung, klare Kommunikation und langjährige Erfahrung — Sicherheit für Arbeitgeber und Arbeitnehmer.',
    iconPath: 'M12 21s-7-5-7-11a7 7 0 0114 0c0 6-7 11-7 11zM12 10m-3 0a3 3 0 1 0 6 0 3 3 0 1 0-6 0',
  },
  {
    title: 'Kompetenz',
    description: 'Dr. Jörg Janssen verbindet über 23 Jahre Erfahrung in der Arbeitsmedizin mit praxisnahen Lösungen.',
    iconPath: 'M20 7L9 18l-5-5',
  },
  {
    title: 'Engagement',
    description: 'Wir begleiten Unternehmen bei Wiedereingliederungen, Gefährdungsbeurteilungen und allen speziellen Anforderungen.',
    iconPath: 'M12 8m-4 0a4 4 0 1 0 8 0 4 4 0 1 0-8 0M12 2v3M12 19v3M2 12h3M19 12h3',
  },
];

---

<BaseLayout
  title="Samedos — Arbeitsmedizin mit Verantwortung | Bremen"
  description="Samedos ist Ihr Partner für moderne Arbeitsmedizin nach DGUV Vorschrift 2. Mit Sitz in Bremen — überregional tätig. Vorsorge, BGM, Spezialuntersuchungen."
>

  <Hero />
  <Stats />

  <!-- Werte -->
  <section class="py-16" id="ueber-uns">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-10">
        <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
          Unsere Werte
        </p>
        <h2>Unser Kompass für Zusammenarbeit und Gesundheit</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {values.map((value) => (
          <ValueCard title={value.title} description={value.description} iconPath={value.iconPath} />
        ))}
      </div>
    </div>
  </section>

  <!-- Leistungen -->
  <section class="bg-bg-soft py-16" id="leistungen">
    <div class="max-w-[860px] mx-auto px-6 text-center" data-animate>
      <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
        Unsere Leistungen
      </p>
      <h2 class="mb-5">Maßgeschneiderte Lösungen für gesunde Mitarbeitende</h2>
      <p class="text-muted text-[1.05rem] mb-8">
        Von arbeitsmedizinischer Vorsorge über Spezialuntersuchungen bis hin zu BGM und psychologischer
        Beratung — wir bieten Unternehmen jeder Größe die passende Lösung.
      </p>
      <a
        href="/leistungen"
        class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
      >
        Alle Leistungen ansehen →
      </a>
    </div>
  </section>

  <!-- Team / Gründer Teaser -->
  <section class="py-16">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-16 items-center">

        <!-- Foto Dr. Janssen -->
        <div class="rounded-3xl overflow-hidden aspect-[4/5] max-w-[440px] mx-auto lg:mx-0 lg:max-w-none" data-animate>
          <img
            src="/images/team/joerg-janssen.png"
            alt="Dr. med. Jörg Janssen"
            class="w-full h-full object-cover object-top"
          />
        </div>

        <!-- Text -->
        <div>
          <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
            Unser Versprechen
          </p>
          <h2>Darauf können Sie sich verlassen</h2>
          <p class="text-muted mt-4 text-[1.05rem]">
            Wir stehen für zuverlässige, rechtssichere und moderne Arbeitsmedizin nach DGUV Vorschrift&nbsp;2.
            Unser Ziel: Ihre Mitarbeitenden langfristig gesund und leistungsfähig zu halten.
          </p>
          <blockquote class="font-heading text-[1.4rem] leading-[1.4] text-mint font-semibold my-6 pl-5 border-l-[3px] border-mint">
            „Arbeitsmedizin ist für mich die Verbindung aus Erfahrung, Verantwortung und
            Menschlichkeit, damit Arbeit und Gesundheit im Einklang bleiben."
          </blockquote>
          <p class="text-navy font-medium">
            Dr. med. Jörg Janssen<br />
            <span class="text-muted font-normal text-[0.9rem]">Gründer &amp; Geschäftsführer</span>
          </p>
        </div>

      </div>
    </div>
  </section>

  <CtaBand />

</BaseLayout>
