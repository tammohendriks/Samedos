---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Services — Samedos Occupational Medicine Bremen"
  description="Our services: occupational health surveillance, workplace health management, specialist examinations (offshore, diving, FEV) and psychological support — based in Bremen, active nationwide."
  lang="en"
  alternateHref="/leistungen"
>

  <!-- Hero -->
  <section class="pt-20 pb-16" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5" data-animate>
        Our services
      </p>
      <h1 class="text-[clamp(2rem,4vw,3rem)] text-white max-w-2xl" data-animate data-delay="1">
        Tailored solutions for a healthy workforce
      </h1>
      <p class="text-white/75 text-[1.1rem] mt-5 max-w-2xl" data-animate data-delay="2">
        Whether preventive examinations, individual consulting concepts or occupational health
        supervision according to DGUV Vorschrift&nbsp;2 — we find the right solution for your company.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-20">
    <div class="max-w-[1200px] mx-auto px-6 space-y-16">
      {[
        {
          number: '01.',
          title: 'Occupational Health Surveillance',
          description: 'Statutory examinations and advisory services according to ASiG and DGUV Vorschrift 2 — for companies of all sizes.',
          items: [
            'Advisory services under the German Occupational Safety Act (ASiG)',
            'Mandatory and voluntary medical surveillance (ArbMedVV)',
            'Employee-requested examinations',
            'Risk assessments',
            'Medical check-ups',
            'Workplace visits and inspections',
          ],
          extra: null,
        },
        {
          number: '02.',
          title: 'Workplace Health Management',
          description: 'Holistic concepts for the long-term health of your workforce — from analysis to implementation.',
          items: [
            'Return-to-work management (BEM)',
            'BGM concepts & health promotion',
            'Vaccination advice & company vaccination campaigns',
            'Workplace ergonomics',
            'Addiction counselling',
            'First aid training (coordination)',
          ],
          extra: null,
        },
        {
          number: '03.',
          title: 'Specialist Examinations',
          description: 'Expert examinations for specific activities and industries — nationally and internationally recognised.',
          items: [
            'Offshore (OGUK/OEUK, NOGEPA/Hardanger, AWMF Germany)',
            'Diving medicine examinations',
            'Radiation protection (X-ray & ionising radiation)',
            'Driving licence FEV (HGV, taxi, emergency services)',
            'Pleasure craft licence',
            'Sports medicine examinations',
          ],
          extra: { href: '/en/services/offshore-medical', label: 'Offshore medical →' },
        },
        {
          number: '04.',
          title: 'Psychological Support & Counselling',
          description: 'Supplementary services for mental health, work-life balance and international assignments.',
          items: [
            'Psychosomatic basic care',
            'Psychological & family-centred counselling',
            'Travel medicine advice',
            'Acupuncture',
          ],
          extra: null,
        },
      ].map((cat, i) => (
        <div data-animate class={`grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-12 items-start ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
          <div class={i % 2 === 1 ? 'lg:[direction:ltr]' : ''}>
            <span class="font-heading font-bold text-mint text-[1.1rem]">{cat.number}</span>
            <h2 class="mt-2 mb-4 text-[1.6rem]">{cat.title}</h2>
            <p class="text-muted">{cat.description}</p>
            <div class="flex flex-wrap gap-3 mt-6">
              <a
                href="/en/contact"
                class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
              >
                Enquire now →
              </a>
              {cat.extra && (
                <a
                  href={cat.extra.href}
                  class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full border border-navy text-navy font-medium text-[0.95rem] transition-all hover:bg-navy hover:text-white"
                >
                  {cat.extra.label}
                </a>
              )}
            </div>
          </div>
          <div class={`bg-white border border-border rounded-2xl p-8 ${i % 2 === 1 ? 'lg:[direction:ltr]' : ''}`}>
            <ul class="space-y-3">
              {cat.items.map((item) => (
                <li class="flex items-start gap-3 text-[0.95rem]">
                  <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-[1200px] mx-auto px-6 pb-24">
    <div
      class="relative rounded-[28px] px-12 py-16 text-center overflow-hidden text-white"
      style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);"
    >
      <div
        class="absolute -top-20 -right-20 w-[300px] h-[300px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(100,197,174,.25), transparent 70%);"
        aria-hidden="true"
      ></div>
      <h2 class="text-white text-[clamp(1.75rem,3vw,2.5rem)] mb-4">Questions about our services?</h2>
      <p class="text-white/80 max-w-[520px] mx-auto mb-7">
        We are happy to advise you — without obligation and free of charge.
        Just get in touch.
      </p>
      <a
        href="/en/contact"
        class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-mint text-navy font-bold text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(100,197,174,.35)]"
      >
        Contact us →
      </a>
    </div>
  </section>

</BaseLayout>
