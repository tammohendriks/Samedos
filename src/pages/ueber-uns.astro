---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTeamMembers } from '../sanity/client';

const team = await getTeamMembers();
---

<BaseLayout
  title="Über uns — Samedos GmbH Bremen"
  description="Samedos wurde 2025 von Dr. Jörg und Simone Janssen gegründet. Lernen Sie unser Team kennen — moderne Arbeitsmedizin mit Erfahrung und Menschlichkeit."
>

  <!-- Hero -->
  <section class="pt-20 pb-16 bg-bg-soft">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-mint font-heading font-semibold text-[0.85rem] tracking-[0.14em] uppercase mb-3.5">
        Über uns
      </p>
      <h1 class="text-[clamp(2rem,4vw,3rem)] max-w-2xl">
        Arbeitsmedizin neu gedacht — aus Bremen.
      </h1>
    </div>
  </section>

  <!-- Geschichte -->
  <section class="py-20">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-mint font-heading font-semibold text-[0.85rem] tracking-[0.14em] uppercase mb-3.5">
            Unsere Geschichte
          </p>
          <h2 class="mb-6">Gegründet mit Überzeugung</h2>
          <div class="space-y-4 text-muted text-[1.05rem]">
            <p>
              Samedos wurde im Oktober 2025 von Dr. Jörg und Simone Janssen gegründet —
              mit dem Ziel, moderne Arbeitsmedizin neu zu denken. Nach vielen Jahren in
              Gemeinschaftspraxis und Krankenhaus bringen die Geschäftsführer umfassende
              Erfahrung und Expertise mit.
            </p>
            <p>
              Gemeinsam mit zwei motivierten medizinischen Fachangestellten bilden wir ein
              kleines, aber eingespieltes Team. Persönlich, verlässlich, auf Augenhöhe.
            </p>
          </div>
          <blockquote class="font-heading text-[1.3rem] leading-[1.4] text-mint font-semibold mt-8 pl-5 border-l-[3px] border-mint">
            „Arbeitsmedizin ist für mich die Verbindung aus Erfahrung, Verantwortung und
            Menschlichkeit, damit Arbeit und Gesundheit im Einklang bleiben."
          </blockquote>
          <p class="mt-4 font-medium text-navy">
            Dr. med. Jörg Janssen
            <span class="block text-muted font-normal text-[0.9rem]">Gründer &amp; Geschäftsführer</span>
          </p>
        </div>

        <!-- Foto-Platzhalter Gründer -->
        <div
          class="rounded-3xl overflow-hidden aspect-[4/5] grid place-items-center text-navy font-medium text-center p-10"
          style="background: linear-gradient(135deg, #E8F6F2, #D6EEE7);"
        >
          <div>
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="mx-auto mb-4">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
            </svg>
            [Platzhalter: Foto Dr. med. Jörg Janssen]
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-bg-soft py-20">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-12">
        <p class="text-mint font-heading font-semibold text-[0.85rem] tracking-[0.14em] uppercase mb-3.5">
          Das Team
        </p>
        <h2>Menschen hinter Samedos</h2>
      </div>

      {team.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {team.map((member) => (
            <div class="bg-white rounded-2xl overflow-hidden border border-border">
              <div
                class="aspect-square bg-mint-soft grid place-items-center"
              >
                {member.photo?.asset?.url ? (
                  <img
                    src={member.photo.asset.url}
                    alt={member.name}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="text-mint opacity-50">
                    <circle cx="12" cy="8" r="4"/>
                    <path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
                  </svg>
                )}
              </div>
              <div class="p-6">
                <h3 class="text-[1.15rem] mb-1">{member.name}</h3>
                <p class="text-mint font-medium text-[0.9rem] mb-3">{member.position}</p>
                {member.bio && <p class="text-muted text-[0.92rem]">{member.bio}</p>}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <!-- Platzhalter wenn noch keine Team-Einträge in Sanity -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { name: 'Dr. med. Jörg Janssen', position: 'Gründer & Geschäftsführer' },
            { name: 'Simone Janssen', position: 'Geschäftsführerin' },
          ].map((member) => (
            <div class="bg-white rounded-2xl overflow-hidden border border-border">
              <div class="aspect-square bg-mint-soft grid place-items-center">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="text-mint opacity-40">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
                </svg>
              </div>
              <div class="p-6">
                <h3 class="text-[1.15rem] mb-1">{member.name}</h3>
                <p class="text-mint font-medium text-[0.9rem]">{member.position}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Werte (kompakt) -->
  <section class="py-20">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-12 text-center max-w-2xl mx-auto">
        <p class="text-mint font-heading font-semibold text-[0.85rem] tracking-[0.14em] uppercase mb-3.5">
          Unsere Werte
        </p>
        <h2>Was uns antreibt</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {['Prävention', 'Verlässlichkeit', 'Nachhaltigkeit', 'Vertrauen', 'Kompetenz', 'Engagement'].map((wert) => (
          <div class="bg-mint-soft rounded-xl p-5 text-center">
            <p class="font-heading font-bold text-navy text-[0.95rem]">{wert}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
