---
import BaseLayout from '../layouts/BaseLayout.astro';
import Slideshow from '../components/Slideshow.astro';
import { getTeamMembers, getGalleryImages } from '../sanity/client';

const [team, sanityGallery] = await Promise.all([getTeamMembers(), getGalleryImages()]);

const localFallbackImages = [
  { src: '/images/gallery/ueber-uns.jpg', alt: 'Das Samedos-Team' },
  { src: '/images/gallery/ueber-uns-1.jpg', alt: 'Einblick in die Praxis' },
  { src: '/images/gallery/ueber-uns-2.jpg', alt: 'Einblick in die Praxis' },
  { src: '/images/gallery/leistungen.jpg', alt: 'Arbeitsmedizinische Leistungen' },
  { src: '/images/gallery/leistungen-1.jpg', alt: 'Untersuchung' },
  { src: '/images/gallery/leistungen-2.jpg', alt: 'Untersuchung' },
];

const galleryImages = sanityGallery.length > 0
  ? sanityGallery.map((img) => ({ src: img.image.asset.url, alt: img.alt }))
  : localFallbackImages;

const fallbackTeam = [
  { name: 'Jörg', position: 'Gründer & Geschäftsführer', photo: '/images/team/joerg-janssen.png' },
  { name: 'Simone', position: 'Gründerin & Geschäftsführerin', photo: '/images/team/simone.png' },
  { name: 'Sigrid', position: 'Medizinische Fachangestellte', photo: '/images/team/sigrid.png' },
  { name: 'Claudia', position: 'Medizinische Fachangestellte', photo: '/images/team/claudia.png' },
];
---

<BaseLayout
  title="Über uns — Samedos GmbH Bremen"
  description="Samedos wurde 2025 von Dr. Jörg und Simone Janssen gegründet. Lernen Sie unser Team kennen — moderne Arbeitsmedizin mit Erfahrung und Menschlichkeit."
>

  <!-- Hero -->
  <section class="pt-20 pb-14" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5" data-animate>
        Über uns
      </p>
      <h1 class="text-[clamp(2rem,4vw,3rem)] text-white max-w-2xl" data-animate data-delay="1">
        Arbeitsmedizin neu gedacht — aus Bremen.
      </h1>
    </div>
  </section>

  <!-- Geschichte -->
  <section class="py-16">
    <div class="max-w-[860px] mx-auto px-6">
      <div data-animate>
        <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
          Unsere Geschichte
        </p>
        <h2 class="mb-6">Gegründet mit Überzeugung</h2>
      </div>
      <div class="space-y-4 text-muted text-[1.05rem]" data-animate data-delay="1">
        <p>
          Samedos wurde im Oktober 2025 von Dr. Jörg und Simone Janssen gegründet —
          mit dem Ziel, moderne Arbeitsmedizin neu zu denken. Nach vielen Jahren in
          Gemeinschaftspraxis und Krankenhaus bringen die Geschäftsführer umfassende
          Erfahrung und Expertise mit.
        </p>
        <p>
          Gemeinsam mit zwei motivierten medizinischen Fachangestellten bilden wir ein
          kleines, aber eingespieltes Team. Persönlich, verlässlich, auf Augenhöhe.
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-bg-soft py-16">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-10" data-animate>
        <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
          Das Team
        </p>
        <h2>Menschen hinter Samedos</h2>
      </div>

      {(() => {
        const displayTeam = team.length > 0
          ? team.map((m) => ({ name: m.name, position: m.position, bio: m.bio ?? '', photo: m.photo?.asset?.url ?? null }))
          : fallbackTeam.map((m) => ({ name: m.name, position: m.position, bio: '', photo: m.photo }));

        return (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {displayTeam.map((member, i) => (
              <div class="bg-white rounded-2xl overflow-hidden border border-border hover:border-mint hover:-translate-y-1 transition-all duration-250" data-animate data-delay={String(i + 1)}>
                <div class="aspect-square bg-mint-soft">
                  {member.photo ? (
                    <img src={member.photo} alt={member.name} class="w-full h-full object-cover object-top" />
                  ) : (
                    <div class="w-full h-full grid place-items-center">
                      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="text-mint opacity-40">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-6">
                  <h3 class="text-[1.1rem] mb-1">{member.name}</h3>
                  <p class="text-mint font-medium text-[0.88rem] mb-2">{member.position}</p>
                  {member.bio && <p class="text-muted text-[0.88rem]">{member.bio}</p>}
                </div>
              </div>
            ))}
          </div>
        );
      })()}
    </div>
  </section>

  <!-- Galerie / Diashow -->
  <section class="py-16">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-8" data-animate>
        <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
          Einblicke
        </p>
        <h2>Das sind wir!</h2>
      </div>
      <div data-animate data-delay="1">
        <Slideshow images={galleryImages} id="gallery-slideshow" />
      </div>
    </div>
  </section>

  <!-- Werte (kompakt) -->
  <section class="py-16 bg-bg-soft">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="mb-10 text-center max-w-2xl mx-auto" data-animate>
        <p class="text-mint font-heading font-semibold text-[1rem] tracking-[0.14em] uppercase mb-3.5">
          Unsere Werte
        </p>
        <h2>Was uns antreibt</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4" data-animate data-delay="1">
        {['Prävention', 'Verlässlichkeit', 'Nachhaltigkeit', 'Vertrauen', 'Kompetenz', 'Engagement'].map((wert) => (
          <div class="bg-white rounded-xl p-5 text-center border border-border">
            <p class="font-heading font-bold text-navy text-[0.95rem]">{wert}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
