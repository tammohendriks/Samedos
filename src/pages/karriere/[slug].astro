---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getActiveJobPostings, getJobPosting, type PortableTextBlock } from '../../sanity/client';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const jobs = await getActiveJobPostings();
  return jobs.map((job) => ({ params: { slug: job.slug.current } }));
}

const { slug } = Astro.params;
const job = await getJobPosting(slug!);

if (!job) return Astro.redirect('/karriere', 302);

const siteUrl = 'https://www.samedos.de';

// description can be legacy string or Portable Text array
const descriptionHtml = Array.isArray(job.description) && job.description.length
  ? toHTML(job.description as PortableTextBlock[])
  : typeof job.description === 'string' && job.description
    ? `<p>${job.description}</p>`
    : '';

function buildDescriptionHtml(j: typeof job): string {
  const parts: string[] = [];
  if (descriptionHtml) parts.push(descriptionHtml);
  if (j!.tasks?.length) {
    parts.push(`<h2>Deine Aufgaben</h2><ul>${j!.tasks.map((t) => `<li>${t}</li>`).join('')}</ul>`);
  }
  if (j!.requirements?.length) {
    parts.push(`<h2>Das bringst du mit</h2><ul>${j!.requirements.map((r) => `<li>${r}</li>`).join('')}</ul>`);
  }
  if (j!.benefits?.length) {
    parts.push(`<h2>Was du bei uns bekommst</h2><ul>${j!.benefits.map((b) => `<li>${b}</li>`).join('')}</ul>`);
  }
  parts.push(`<p>Bewerbungen bitte per E-Mail an janssen@samedos.de. Standort: ${j!.location ?? 'Bremen'}.</p>`);
  return parts.join('\n');
}

function scopeToEmploymentType(scope?: string): string[] {
  if (scope === 'Vollzeit / Teilzeit') return ['FULL_TIME', 'PART_TIME'];
  if (scope === 'Teilzeit') return ['PART_TIME'];
  if (scope === 'Minijob') return ['PART_TIME'];
  return ['FULL_TIME'];
}

const datePosted = new Date(job.publishedAt ?? Date.now()).toISOString();
const validThrough = job.validThrough
  ? new Date(job.validThrough).toISOString()
  : new Date(new Date(job.publishedAt ?? Date.now()).getTime() + 90 * 24 * 60 * 60 * 1000).toISOString();

const jobPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: job.title,
  description: buildDescriptionHtml(job),
  datePosted,
  validThrough,
  employmentType: scopeToEmploymentType(job.scope),
  hiringOrganization: {
    '@type': 'Organization',
    name: 'Samedos GmbH',
    sameAs: siteUrl,
    logo: `${siteUrl}/logo-new.svg`,
  },
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Timmersloher Straße 82',
      addressLocality: 'Bremen',
      postalCode: '28215',
      addressRegion: 'HB',
      addressCountry: 'DE',
    },
  },
  directApply: true,
  url: `${siteUrl}/karriere/${job.slug.current}`,
  identifier: {
    '@type': 'PropertyValue',
    name: 'Samedos GmbH',
    value: job._id,
  },
};

const metaTitle = `${job.title} – Karriere bei Samedos Bremen`;
const plainDescription = Array.isArray(job.description)
  ? job.description.flatMap((b) => b.children?.map((s: { text: string }) => s.text) ?? []).join(' ')
  : (job.description as unknown as string) ?? 'Jetzt bewerben.';
const metaDescription = `${job.title} bei Samedos Arbeitsmedizin in Bremen. ${plainDescription}`.slice(0, 155);
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)} />
  </Fragment>

  <section class="pt-20 pb-16" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <a href="/karriere" class="text-mint text-[0.9rem] hover:text-white transition-colors">← Alle Stellen</a>
      <div class="flex flex-wrap items-start justify-between gap-6 mt-6">
        <div>
          <h1 class="text-[clamp(1.75rem,3.5vw,2.75rem)] text-white">{job.title}</h1>
          <div class="flex flex-wrap gap-3 mt-3">
            {job.scope && (
              <span class="text-[0.85rem] bg-white/15 text-white px-3 py-1 rounded-full font-medium">{job.scope}</span>
            )}
            {job.location && (
              <span class="text-[0.85rem] text-white/65">{job.location}</span>
            )}
          </div>
        </div>
        <a
          href={`mailto:janssen@samedos.de?subject=Bewerbung: ${job.title}`}
          class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-mint text-navy font-bold text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(100,197,174,.35)]"
        >
          Jetzt bewerben →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-[800px] mx-auto px-6 space-y-12">

      {descriptionHtml && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Über die Stelle</h2>
          <div class="text-muted text-[1.05rem] space-y-4 [&_strong]:text-navy [&_strong]:font-semibold" set:html={descriptionHtml} />
        </div>
      )}

      {job.tasks && job.tasks.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Deine Aufgaben</h2>
          <ul class="space-y-3">
            {job.tasks.map((task) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{task}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {job.requirements && job.requirements.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Das bringst du mit</h2>
          <ul class="space-y-3">
            {job.requirements.map((req) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{req}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {job.benefits && job.benefits.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Was du bei uns bekommst</h2>
          <ul class="space-y-3">
            {job.benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="bg-mint-soft rounded-2xl p-8">
        <h2 class="text-[1.3rem] mb-3">Klingt gut?</h2>
        <p class="text-muted mb-5">
          Schick uns deine Bewerbung direkt per E-Mail an{' '}
          <a href="mailto:janssen@samedos.de" class="text-mint font-medium">janssen@samedos.de</a>{' '}
          — wir freuen uns auf dich!
        </p>
        <a
          href={`mailto:janssen@samedos.de?subject=Bewerbung: ${job.title}`}
          class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
        >
          Jetzt bewerben →
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
