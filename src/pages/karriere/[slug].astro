---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getActiveJobPostings, getJobPosting } from '../../sanity/client';

export async function getStaticPaths() {
  const jobs = await getActiveJobPostings();
  return jobs.map((job) => ({ params: { slug: job.slug.current } }));
}

const { slug } = Astro.params;
const job = await getJobPosting(slug!);

if (!job) return Astro.redirect('/karriere', 302);
---

<BaseLayout
  title={`${job.title} — Karriere bei Samedos`}
  description={job.description ?? `Jetzt als ${job.title} bei Samedos in Bremen bewerben.`}
>

  <section class="pt-20 pb-16" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <a href="/karriere" class="text-mint text-[0.9rem] hover:text-white transition-colors">← Alle Stellen</a>
      <div class="flex flex-wrap items-start justify-between gap-6 mt-6">
        <div>
          <h1 class="text-[clamp(1.75rem,3.5vw,2.75rem)] text-white">{job.title}</h1>
          <div class="flex flex-wrap gap-3 mt-3">
            {job.scope && (
              <span class="text-[0.85rem] bg-white/15 text-white px-3 py-1 rounded-full font-medium">{job.scope}</span>
            )}
            {job.location && (
              <span class="text-[0.85rem] text-white/65">{job.location}</span>
            )}
          </div>
        </div>
        <a
          href={`mailto:janssen@samedos.de?subject=Bewerbung: ${job.title}`}
          class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-mint text-navy font-bold text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(100,197,174,.35)]"
        >
          Jetzt bewerben →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-[800px] mx-auto px-6 space-y-12">

      {job.description && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Über die Stelle</h2>
          <p class="text-muted text-[1.05rem]">{job.description}</p>
        </div>
      )}

      {job.tasks && job.tasks.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Deine Aufgaben</h2>
          <ul class="space-y-3">
            {job.tasks.map((task) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{task}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {job.requirements && job.requirements.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Das bringst du mit</h2>
          <ul class="space-y-3">
            {job.requirements.map((req) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{req}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="bg-mint-soft rounded-2xl p-8">
        <h2 class="text-[1.3rem] mb-3">Klingt gut?</h2>
        <p class="text-muted mb-5">
          Schick uns deine Bewerbung direkt per E-Mail an{' '}
          <a href="mailto:janssen@samedos.de" class="text-mint font-medium">janssen@samedos.de</a>{' '}
          — wir freuen uns auf dich!
        </p>
        <a
          href={`mailto:janssen@samedos.de?subject=Bewerbung: ${job.title}`}
          class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
        >
          Jetzt bewerben →
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
