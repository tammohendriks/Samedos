---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getActiveJobPostings, getJobPosting, type PortableTextBlock } from '../../sanity/client';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const jobs = await getActiveJobPostings();
  return jobs.map((job) => ({ params: { slug: job.slug.current } }));
}

const { slug } = Astro.params;
const job = await getJobPosting(slug!);

if (!job) return Astro.redirect('/karriere', 302);

const siteUrl = 'https://www.samedos.de';

function renderPortableText(blocks: unknown): string {
  if (Array.isArray(blocks) && blocks.length) return toHTML(blocks as PortableTextBlock[]);
  if (typeof blocks === 'string' && blocks) return `<p>${blocks}</p>`;
  return '';
}

const descriptionHtml  = renderPortableText(job.description);
const whatToExpectHtml = renderPortableText(job.whatToExpect);

function buildDescriptionHtml(): string {
  const parts: string[] = [];
  if (descriptionHtml)  parts.push(descriptionHtml);
  if (whatToExpectHtml) parts.push(`<h2>Was dich bei uns erwartet</h2>${whatToExpectHtml}`);
  if (job.tasksOutdoor?.length || job.tasksOffice?.length) {
    parts.push('<h2>Deine Aufgaben im Überblick</h2>');
    if (job.tasksOutdoor?.length)
      parts.push(`<h3>${job.tasksOutdoorTitle ?? 'Im Außendienst'}</h3><ul>${job.tasksOutdoor.map((t) => `<li>${t}</li>`).join('')}</ul>`);
    if (job.tasksOffice?.length)
      parts.push(`<h3>${job.tasksOfficeTitle ?? 'In der Praxis in Findorff'}</h3><ul>${job.tasksOffice.map((t) => `<li>${t}</li>`).join('')}</ul>`);
  }
  if (job.requirements?.length)
    parts.push(`<h2>Was du mitbringst</h2><ul>${job.requirements.map((r) => `<li>${r}</li>`).join('')}</ul>`);
  if (job.benefits?.length)
    parts.push(`<h2>Was du bei uns bekommst</h2><ul>${job.benefits.map((b) => `<li>${b}</li>`).join('')}</ul>`);
  parts.push(`<p>Bewerbungen per E-Mail an janssen@samedos.de oder telefonisch unter 0421 354366. Standort: ${job.location ?? 'Bremen'}.</p>`);
  return parts.join('\n');
}

function scopeToEmploymentType(scope?: string): string[] {
  if (scope === 'Vollzeit / Teilzeit') return ['FULL_TIME', 'PART_TIME'];
  if (scope === 'Teilzeit') return ['PART_TIME'];
  if (scope === 'Minijob') return ['PART_TIME'];
  return ['FULL_TIME'];
}

const datePosted = new Date(job.publishedAt ?? Date.now()).toISOString();
const validThrough = job.validThrough
  ? new Date(job.validThrough).toISOString()
  : new Date(new Date(job.publishedAt ?? Date.now()).getTime() + 90 * 24 * 60 * 60 * 1000).toISOString();

const jobPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: job.title,
  description: buildDescriptionHtml(),
  datePosted,
  validThrough,
  employmentType: scopeToEmploymentType(job.scope),
  hiringOrganization: {
    '@type': 'Organization',
    name: 'Samedos GmbH',
    sameAs: siteUrl,
    logo: `${siteUrl}/logo-new.svg`,
  },
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Timmersloher Straße 82',
      addressLocality: 'Bremen',
      postalCode: '28215',
      addressRegion: 'HB',
      addressCountry: 'DE',
    },
  },
  directApply: true,
  ...(job.startDate && { jobStartDate: job.startDate }),
  baseSalary: {
    '@type': 'MonetaryAmount',
    currency: 'EUR',
    value: {
      '@type': 'QuantitativeValue',
      minValue: job.salaryMin ?? 2300,
      maxValue: job.salaryMax ?? 3200,
      unitText: job.salaryUnit ?? 'MONTH',
    },
  },
  url: `${siteUrl}/karriere/${job.slug.current}`,
  identifier: {
    '@type': 'PropertyValue',
    name: 'Samedos GmbH',
    value: job._id,
  },
};

const metaTitle = `${job.title} – Karriere bei Samedos Bremen`;
const plainIntro = Array.isArray(job.description)
  ? job.description.flatMap((b) => b.children?.map((s: { text: string }) => s.text) ?? []).join(' ')
  : (job.description as unknown as string) ?? 'Jetzt bewerben.';
const metaDescription = `${job.title} bei Samedos Arbeitsmedizin in Bremen. ${plainIntro}`.slice(0, 155);

const richTextClasses = 'text-muted text-[1.05rem] space-y-4 [&_strong]:text-navy [&_strong]:font-semibold [&_em]:italic';
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)} />
  </Fragment>

  <section class="pt-20 pb-16" style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
    <div class="max-w-[1200px] mx-auto px-6">
      <a href="/karriere" class="text-mint text-[0.9rem] hover:text-white transition-colors">← Alle Stellen</a>
      <div class="flex flex-wrap items-start justify-between gap-6 mt-6">
        <div>
          <h1 class="text-[clamp(1.75rem,3.5vw,2.75rem)] text-white">{job.title}</h1>
          <div class="flex flex-wrap gap-3 mt-3">
            {job.scope && (
              <span class="text-[0.85rem] bg-white/15 text-white px-3 py-1 rounded-full font-medium">{job.scope}</span>
            )}
            {job.startDate && (
              <span class="text-[0.85rem] bg-mint/20 text-mint px-3 py-1 rounded-full font-medium">Besetzung: {job.startDate}</span>
            )}
            {job.location && (
              <span class="text-[0.85rem] text-white/65">{job.location}</span>
            )}
          </div>
        </div>
        <a
          href={`mailto:janssen@samedos.de?subject=Bewerbung: ${job.title}`}
          class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-mint text-navy font-bold text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(100,197,174,.35)]"
        >
          Jetzt bewerben →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-[800px] mx-auto px-6 space-y-12">

      {descriptionHtml && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Einleitung</h2>
          <div class={richTextClasses} set:html={descriptionHtml} />
        </div>
      )}

      {whatToExpectHtml && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Was dich bei uns erwartet</h2>
          <div class={richTextClasses} set:html={whatToExpectHtml} />
        </div>
      )}

      {(job.tasksOutdoor?.length || job.tasksOffice?.length) && (
        <div>
          <h2 class="text-[1.4rem] mb-6">Deine Aufgaben im Überblick</h2>
          <div class="space-y-8">
            {job.tasksOutdoor && job.tasksOutdoor.length > 0 && (
              <div>
                <h3 class="text-[1.05rem] font-semibold text-navy mb-3">{job.tasksOutdoorTitle ?? 'Im Außendienst'}</h3>
                <ul class="space-y-3">
                  {job.tasksOutdoor.map((task) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                      <span class="text-muted">{task}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {job.tasksOffice && job.tasksOffice.length > 0 && (
              <div>
                <h3 class="text-[1.05rem] font-semibold text-navy mb-3">{job.tasksOfficeTitle ?? 'In der Praxis in Findorff'}</h3>
                <ul class="space-y-3">
                  {job.tasksOffice.map((task) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                      <span class="text-muted">{task}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      )}

      {job.requirements && job.requirements.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Was du mitbringst</h2>
          <ul class="space-y-3">
            {job.requirements.map((req) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{req}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {job.benefits && job.benefits.length > 0 && (
        <div>
          <h2 class="text-[1.4rem] mb-4">Was du bei uns bekommst</h2>
          <ul class="space-y-3">
            {job.benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 bg-mint rounded-full shrink-0"></span>
                <span class="text-muted">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="bg-mint-soft rounded-2xl p-8">
        <h2 class="text-[1.3rem] mb-3">Klingt nach dir?</h2>
        <p class="text-muted mb-2">
          Dann freuen wir uns auf deine Bewerbung — ganz unkompliziert per Mail an{' '}
          <a href="mailto:janssen@samedos.de" class="text-mint font-medium">janssen@samedos.de</a>.
          Anschreiben, Lebenslauf und Zeugnisse reichen uns.
        </p>
        <p class="text-muted mb-6">
          Bei Fragen meldest du dich gern vorab telefonisch unter{' '}
          <a href="tel:0421354366" class="text-mint font-medium">0421 354366</a> — wir nehmen uns Zeit.
        </p>
        <p class="text-[0.9rem] text-navy font-medium mb-6">Jörg & Simone</p>
        <a
          href={`mailto:janssen@samedos.de?subject=Bewerbung: ${job.title}`}
          class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
        >
          Jetzt bewerben →
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
