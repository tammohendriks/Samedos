---
interface Props {
  alternateHref?: string;
  lang?: 'de' | 'en';
}

const { alternateHref, lang = 'de' } = Astro.props;
const currentPath = Astro.url.pathname;
const isEnglish = lang === 'en';
const homeHref = isEnglish ? '/en/' : '/';
const isHome = currentPath === homeHref || currentPath === (isEnglish ? '/en' : '/');

const leistungenItems = isEnglish
  ? [
      { href: '/en/services', label: 'All Services', desc: 'Overview of all offerings' },
      { href: '/en/services/offshore-medical', label: 'Offshore Medical', desc: 'OGUK/OEUK, AWMF & Hardanger' },
    ]
  : [
      { href: '/leistungen', label: 'Alle Leistungen', desc: 'Übersicht aller Angebote' },
      { href: '/leistungen/offshore-untersuchung', label: 'Offshore-Untersuchung', desc: 'OGUK/OEUK, AWMF & Hardanger' },
    ];

const navLinks = isEnglish
  ? [
      { href: '/en/prices', label: 'Prices' },
      { href: '/en/about', label: 'About us' },
    ]
  : [
      { href: '/preise', label: 'Preise' },
      { href: '/ueber-uns', label: 'Über uns' },
      { href: '/karriere', label: 'Karriere' },
    ];

const leistungenActive = isEnglish
  ? currentPath.startsWith('/en/services')
  : currentPath.startsWith('/leistungen');

const leistungenLabel = isEnglish ? 'Services' : 'Leistungen';
const homeLabel = isEnglish ? 'Home' : 'Startseite';
const showSwitcher = !!alternateHref;
---

<header class="sticky top-0 z-50 bg-white/85 backdrop-blur-md [backdrop-filter:saturate(160%)_blur(12px)] border-b border-border">
  <div class="max-w-[1200px] mx-auto px-6 flex items-center justify-between py-3">

    <a href={homeHref} class="flex items-center gap-2 shrink-0" aria-label="Samedos – Startseite">
      <img src="/logo-new.svg" alt="Samedos" class="h-24 w-auto" />
    </a>

    <nav class="flex items-center gap-6" aria-label="Hauptnavigation">

      {!isHome && (
        <a href={homeHref} class="nav-home-link font-medium text-[0.95rem] text-navy transition-colors hover:text-mint hidden md:block">
          {homeLabel}
        </a>
      )}

      <!-- Leistungen Dropdown (Desktop) -->
      <div class="relative hidden md:block" id="leistungen-dropdown">
        <button
          id="leistungen-btn"
          aria-haspopup="true"
          aria-expanded="false"
          class={`flex items-center gap-1 font-medium text-[0.95rem] transition-colors hover:text-mint ${leistungenActive ? 'text-mint' : 'text-navy'}`}
        >
          {leistungenLabel}
          <svg id="leistungen-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform duration-200" aria-hidden="true">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>

        <div
          id="leistungen-panel"
          role="menu"
          aria-label="Leistungen"
          class="absolute top-full left-1/2 -translate-x-1/2 w-64 pt-2.5 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none"
        >
          <div class="bg-white border border-border rounded-2xl shadow-[0_8px_32px_rgba(20,43,73,.12)] overflow-hidden">
          <!-- Kleiner Pfeil nach oben -->
          <div class="absolute top-[4px] left-1/2 -translate-x-1/2 w-3 h-3 bg-white border-l border-t border-border rotate-45"></div>
          <div class="p-2">
            {leistungenItems.map((item) => (
              <a
                href={item.href}
                role="menuitem"
                class={`flex flex-col gap-0.5 px-4 py-3 rounded-xl transition-colors hover:bg-bg-soft group ${currentPath === item.href ? 'bg-bg-soft' : ''}`}
              >
                <span class={`font-heading font-semibold text-[0.9rem] transition-colors group-hover:text-mint ${currentPath === item.href ? 'text-mint' : 'text-navy'}`}>
                  {item.label}
                </span>
                <span class="text-muted text-[0.78rem]">{item.desc}</span>
              </a>
            ))}
          </div>
          </div>
        </div>
      </div>

      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-medium text-[0.95rem] transition-colors hover:text-mint hidden md:block ${currentPath.startsWith(link.href) ? 'text-mint' : 'text-navy'}`}
        >
          {link.label}
        </a>
      ))}

      {showSwitcher && (
        <a
          href={alternateHref}

          aria-label={isEnglish ? 'Zur deutschen Version wechseln' : 'Switch to English version'}
          class="hidden md:inline-flex items-center justify-center w-9 h-9 rounded-full border border-border text-navy font-medium text-[0.78rem] tracking-wide transition-colors hover:bg-bg-soft"
        >
          {isEnglish ? 'DE' : 'EN'}
        </a>
      )}

      <a
        href={isEnglish ? '/en/contact' : '/kontakt'}
        class="hidden md:inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-navy text-white font-medium text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(20,43,73,.25)]"
      >
        {isEnglish ? 'Contact' : 'Kontakt'}
      </a>

      <!-- Hamburger (mobile only) -->
      <button
        id="menu-toggle"
        aria-label="Menü öffnen"
        class="md:hidden flex flex-col justify-center items-center gap-[5px] w-10 h-10 rounded-lg hover:bg-bg-soft transition-colors"
      >
        <span class="block w-5 h-[2px] bg-navy rounded-full transition-all origin-center" id="bar1"></span>
        <span class="block w-5 h-[2px] bg-navy rounded-full transition-all" id="bar2"></span>
        <span class="block w-5 h-[2px] bg-navy rounded-full transition-all origin-center" id="bar3"></span>
      </button>
    </nav>

  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-white flex flex-col px-6 py-6 gap-0 translate-x-full transition-transform duration-300 ease-in-out md:hidden overflow-y-auto"
  aria-hidden="true"
>
  <div class="flex items-center justify-between mb-6">
    <img src="/logo-new.svg" alt="Samedos" class="h-16 w-auto" />
    <button
      id="menu-close"
      aria-label="Menü schließen"
      class="w-12 h-12 flex items-center justify-center rounded-xl bg-bg-soft active:bg-border transition-colors"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  {!isHome && (
    <a href={homeHref} class="nav-home-link text-navy font-heading font-bold text-[1.3rem] border-b border-border py-4 hover:text-mint transition-colors">
      {homeLabel}
    </a>
  )}

  <!-- Leistungen Accordion (Mobile) -->
  <div class="border-b border-border">
    <button
      id="mobile-leistungen-btn"
      aria-expanded="false"
      class={`w-full flex items-center justify-between py-4 font-heading font-bold text-[1.3rem] transition-colors ${leistungenActive ? 'text-mint' : 'text-navy'}`}
    >
      {leistungenLabel}
      <svg id="mobile-leistungen-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform duration-200" aria-hidden="true">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </button>
    <div id="mobile-leistungen-panel" class="hidden pb-2 space-y-1 pl-2">
      {leistungenItems.map((item) => (
        <a
          href={item.href}
          class={`flex flex-col gap-0.5 px-3 py-3 rounded-xl transition-colors hover:bg-bg-soft ${currentPath === item.href ? 'bg-bg-soft' : ''}`}
        >
          <span class={`font-heading font-semibold text-[1rem] ${currentPath === item.href ? 'text-mint' : 'text-navy'}`}>{item.label}</span>
          <span class="text-muted text-[0.82rem]">{item.desc}</span>
        </a>
      ))}
    </div>
  </div>

  {navLinks.map((link) => (
    <a
      href={link.href}
      class={`font-heading font-bold text-[1.3rem] border-b border-border py-4 transition-colors ${currentPath.startsWith(link.href) ? 'text-mint' : 'text-navy hover:text-mint'}`}
    >
      {link.label}
    </a>
  ))}

  <div class="mt-4 flex gap-3">
    <a
      href={isEnglish ? '/en/contact' : '/kontakt'}
      class="flex-1 inline-flex items-center justify-center gap-2 px-[22px] py-4 rounded-full bg-navy text-white font-medium text-[1rem]"
    >
      {isEnglish ? 'Contact →' : 'Kontakt →'}
    </a>
    {showSwitcher && (
      <a
        href={alternateHref}
        data-lang-switch
        aria-label={isEnglish ? 'Zur deutschen Version wechseln' : 'Switch to English version'}
        class="inline-flex items-center justify-center w-14 rounded-full border border-border text-navy font-medium text-[0.9rem] tracking-wide transition-colors hover:bg-bg-soft"
      >
        {isEnglish ? 'DE' : 'EN'}
      </a>
    )}
  </div>
</div>

<style>
  @keyframes nav-home-fade {
    from { opacity: 0; transform: translateY(-5px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .nav-home-link {
    animation: nav-home-fade 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-home-link { animation: none; }
  }
</style>

<script is:inline>
(function () {
  // ── Desktop Dropdown ──────────────────────────────────────────────
  var btn = document.getElementById('leistungen-btn');
  var panel = document.getElementById('leistungen-panel');
  var chevron = document.getElementById('leistungen-chevron');
  var container = document.getElementById('leistungen-dropdown');
  var isOpen = false;

  function openDropdown() {
    isOpen = true;
    btn.setAttribute('aria-expanded', 'true');
    panel.classList.remove('opacity-0', 'invisible', 'translate-y-1', 'pointer-events-none');
    panel.classList.add('opacity-100', 'visible', 'translate-y-0');
    chevron.style.transform = 'rotate(180deg)';
  }

  function closeDropdown() {
    isOpen = false;
    btn.setAttribute('aria-expanded', 'false');
    panel.classList.add('opacity-0', 'invisible', 'translate-y-1', 'pointer-events-none');
    panel.classList.remove('opacity-100', 'visible', 'translate-y-0');
    chevron.style.transform = '';
  }

  if (btn && panel) {
    // Hover
    container.addEventListener('mouseenter', openDropdown);
    container.addEventListener('mouseleave', closeDropdown);

    // Click/keyboard toggle
    btn.addEventListener('click', function () { isOpen ? closeDropdown() : openDropdown(); });

    // Keyboard: Escape closes
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) { closeDropdown(); btn.focus(); }
    });

    // Close when clicking outside
    document.addEventListener('click', function (e) {
      if (!container.contains(e.target)) closeDropdown();
    });

    // Arrow key navigation inside panel
    btn.addEventListener('keydown', function (e) {
      if ((e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') && !isOpen) {
        e.preventDefault();
        openDropdown();
        var first = panel.querySelector('a');
        if (first) first.focus();
      }
    });

    var menuItems = panel.querySelectorAll('a');
    menuItems.forEach(function (item, idx) {
      item.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowDown') { e.preventDefault(); if (menuItems[idx + 1]) menuItems[idx + 1].focus(); }
        if (e.key === 'ArrowUp')   { e.preventDefault(); if (menuItems[idx - 1]) menuItems[idx - 1].focus(); else btn.focus(); }
        if (e.key === 'Escape')    { closeDropdown(); btn.focus(); }
        if (e.key === 'Tab')       { closeDropdown(); }
      });
    });
  }

  // ── Mobile Menu ───────────────────────────────────────────────────
  var toggle = document.getElementById('menu-toggle');
  var mobileMenu = document.getElementById('mobile-menu');
  var closeBtn = document.getElementById('menu-close');
  var bar1 = document.getElementById('bar1');
  var bar2 = document.getElementById('bar2');
  var bar3 = document.getElementById('bar3');

  function openMenu() {
    mobileMenu.classList.remove('translate-x-full');
    mobileMenu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    bar1.style.transform = 'translateY(7px) rotate(45deg)';
    bar2.style.opacity = '0';
    bar3.style.transform = 'translateY(-7px) rotate(-45deg)';
  }

  function closeMobileMenu() {
    mobileMenu.classList.add('translate-x-full');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    bar1.style.transform = '';
    bar2.style.opacity = '';
    bar3.style.transform = '';
  }

  if (toggle) toggle.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMobileMenu);

  if (mobileMenu) {
    mobileMenu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMobileMenu);
    });
  }

  // ── Mobile Leistungen Accordion ───────────────────────────────────
  var mobileLeistungenBtn = document.getElementById('mobile-leistungen-btn');
  var mobileLeistungenPanel = document.getElementById('mobile-leistungen-panel');
  var mobileLeistungenChevron = document.getElementById('mobile-leistungen-chevron');

  if (mobileLeistungenBtn && mobileLeistungenPanel) {
    mobileLeistungenBtn.addEventListener('click', function () {
      var expanded = mobileLeistungenBtn.getAttribute('aria-expanded') === 'true';
      mobileLeistungenBtn.setAttribute('aria-expanded', String(!expanded));
      mobileLeistungenPanel.classList.toggle('hidden');
      mobileLeistungenChevron.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  }
})();
</script>
