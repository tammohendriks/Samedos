---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: 'de' | 'en';
  alternateHref?: string;
}

const { title, description, ogImage = '/og-default.jpg', noindex = false, lang = 'de', alternateHref } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const site = 'https://samedos.de';

const deHref = lang === 'de' ? canonicalURL.href : alternateHref ? `${site}${alternateHref}` : null;
const enHref = lang === 'en' ? canonicalURL.href : alternateHref ? `${site}${alternateHref}` : null;
const ogLocale = lang === 'en' ? 'en_US' : 'de_DE';
const ogImageUrl = new URL(ogImage, Astro.site).href;

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': ['MedicalBusiness', 'LocalBusiness'],
  name: 'Samedos GmbH',
  description: 'Arbeitsmedizin mit Verantwortung — moderne Arbeitsmedizin nach DGUV Vorschrift 2',
  url: 'https://samedos.de',
  telephone: '+494216399776',
  email: 'info@samedos.de',
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Timmersloher Straße 82',
    addressLocality: 'Bremen',
    postalCode: '28215',
    addressCountry: 'DE',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '15:00',
    },
  ],
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 53.0757,
    longitude: 8.8107,
  },
  sameAs: ['https://samedos.de'],
};
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href="/sitemap-index.xml" />
{noindex && <meta name="robots" content="noindex,nofollow" />}

{deHref && <link rel="alternate" hreflang="de" href={deHref} />}
{enHref && <link rel="alternate" hreflang="en" href={enHref} />}
{deHref && <link rel="alternate" hreflang="x-default" href={deHref} />}

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content="website" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="Samedos GmbH" />

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
