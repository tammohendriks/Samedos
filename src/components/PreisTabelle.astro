---
import type { PreisTabelleDaten } from '../data/preise';

interface Props {
  daten: PreisTabelleDaten;
  modus?: 'standard' | 'g-untersuchungen' | 'sonderuntersuchungen' | 'labor' | 'impfungen';
  lang?: 'de' | 'en';
}

const { daten, modus = 'standard', lang = 'de' } = Astro.props;
const isEN = lang === 'en';

// Only show the code/extra column if at least one row actually has a code value
const hasCode = daten.sektionen.some(s => s.zeilen.some(z => z.code));

const extraLinksHeader = hasCode
  ? (modus === 'g-untersuchungen' ? 'Code'
    : modus === 'sonderuntersuchungen' ? (isEN ? 'Examination' : 'Untersuchung')
    : null)
  : null;

const bezeichnungHeader = isEN ? 'Description'
  : modus === 'labor' ? 'Laborleistung'
  : 'Bezeichnung';

const preisHeader = isEN ? 'Price (net)' : 'Preis (netto)';
---

<div class="mt-6 space-y-8 preistabelle">
  {daten.sektionen.map((sektion) => (
    <div>
      <div class="bg-navy/5 border-l-4 border-mint px-4 py-2 mb-0 rounded-tr-lg">
        <p class="font-heading font-semibold text-navy text-[0.9rem] tracking-wide">{sektion.titel}</p>
      </div>
      <div class="border border-border rounded-b-xl overflow-x-auto">
        <table class="w-full text-[0.9rem] border-collapse">
          <colgroup>
            {extraLinksHeader && <col class="w-28" />}
            <col class="w-full" />
            <col class="w-36" />
          </colgroup>
          <thead>
            <tr class="border-b border-border bg-bg-soft">
              {extraLinksHeader && (
                <th class="text-left px-4 py-2.5 font-semibold text-navy whitespace-nowrap">{extraLinksHeader}</th>
              )}
              <th class="text-left px-4 py-2.5 font-semibold text-navy">{bezeichnungHeader}</th>
              <th class="text-right px-4 py-2.5 font-semibold text-navy whitespace-nowrap">{preisHeader}</th>
            </tr>
          </thead>
          <tbody>
            {sektion.zeilen.map((zeile, i) => (
              <tr class={`border-b border-border last:border-0 ${i % 2 === 0 ? '' : 'bg-bg-soft/50'}`}>
                {extraLinksHeader && (
                  <td class="px-4 py-2.5 text-muted whitespace-nowrap font-mono text-[0.82rem]">{zeile.code ?? ''}</td>
                )}
                <td class="px-4 py-2.5 text-muted">{zeile.bezeichnung}</td>
                <td class="px-4 py-2.5 text-right font-medium text-navy whitespace-nowrap">
                  {zeile.preis
                    ? <>{zeile.preis}{zeile.einheit ? <span class="text-muted font-normal text-[0.8rem] ml-1">{zeile.einheit}</span> : ''}</>
                    : <span class="text-muted font-normal">{zeile.hinweis ?? '–'}</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</div>
