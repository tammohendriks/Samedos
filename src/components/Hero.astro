---
---

<section class="relative pt-24 pb-20 overflow-hidden">
  <!-- decorative radial gradient blob -->
  <div
    class="absolute -top-[200px] -right-[200px] w-[650px] h-[650px] rounded-full pointer-events-none -z-10"
    style="background: radial-gradient(circle, #D6EEE7 0%, transparent 60%); filter: blur(10px);"
    aria-hidden="true"
  ></div>

  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-16 items-center">

      <!-- Text column -->
      <div>
        <p class="text-mint font-heading font-semibold text-[0.85rem] tracking-[0.14em] uppercase mb-3.5">
          Arbeitsmedizin aus Bremen
        </p>
        <h1 class="text-[clamp(2.25rem,5vw,4rem)] mt-2 mb-6">
          Arbeitsmedizin mit <span class="text-mint inline-block">Verantwortung.</span>
        </h1>
        <p class="text-[1.15rem] text-muted mb-8 max-w-[520px]">
          Samedos ist Ihr Partner für moderne Arbeitsmedizin nach DGUV Vorschrift&nbsp;2.
          Wir schützen die Gesundheit Ihrer Mitarbeitenden — mit persönlicher Betreuung,
          fachlicher Expertise und klaren Konzepten.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a
            href="/kontakt"
            class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full bg-mint text-navy font-bold text-[0.95rem] transition-all hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(100,197,174,.35)]"
          >
            Termin anfragen →
          </a>
          <a
            href="/leistungen"
            class="inline-flex items-center gap-2 px-[22px] py-3 rounded-full border-[1.5px] border-navy text-navy font-medium text-[0.95rem] transition-all hover:bg-navy hover:text-white"
          >
            Leistungen ansehen
          </a>
        </div>
      </div>

      <!-- Image column -->
      <div class="relative rounded-3xl overflow-hidden aspect-[4/5] max-w-[440px] mx-auto lg:mx-0 lg:max-w-none shadow-[0_20px_60px_rgba(20,43,73,.2)]"
           style="background: linear-gradient(135deg, #142B49 0%, #29466B 100%);">
        <!-- placeholder content -->
        <div class="flex items-end justify-center h-full text-white/70 p-10 text-center text-[0.9rem]">
          <div>
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.2" class="mx-auto mb-4 opacity-35">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
            </svg>
            [Platzhalter: Teamfoto Samedos]
          </div>
        </div>

        <!-- floating badge -->
        <div class="absolute bottom-6 left-6 bg-white rounded-2xl px-5 py-4 shadow-[0_10px_30px_rgba(20,43,73,.12)] flex items-center gap-3">
          <span class="w-2.5 h-2.5 bg-mint rounded-full shadow-[0_0_0_4px_rgba(100,197,174,.25)] shrink-0"></span>
          <span class="text-[0.9rem] font-medium text-navy">Auch außerhalb der Öffnungszeiten erreichbar</span>
        </div>
      </div>

    </div>
  </div>
</section>
