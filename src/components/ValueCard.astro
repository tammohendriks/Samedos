---
interface Props {
  title: string;
  description: string;
  iconPath: string;
}

const { title, description, iconPath } = Astro.props;
---

<div data-animate class="bg-white border border-border rounded-[18px] p-7 transition-all duration-250 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(20,43,73,.08)] hover:border-mint">
  <div class="w-11 h-11 bg-mint-soft rounded-xl grid place-items-center text-mint mb-[18px]">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[22px] h-[22px]">
      <path d={iconPath} />
    </svg>
  </div>
  <h3 class="text-[1.2rem] mb-2">{title}</h3>
  <p class="text-muted text-[0.95rem]">{description}</p>
</div>
