---
const stats = [
  { number: '+80', label: 'betreute Unternehmen' },
  { number: '+800', label: 'betreute Mitarbeitende' },
  { number: '36+', label: 'Jahre Erfahrung' },
  { number: '100%', label: 'individuelle Konzepte' },
];
---

<section class="bg-bg-soft py-14">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-10 text-center">
      {stats.map((stat) => (
        <div>
          <div class="font-heading font-extrabold text-mint leading-none mb-2"
               style="font-size: clamp(2.2rem, 4vw, 3.2rem);">
            {stat.number}
          </div>
          <div class="text-[0.95rem] text-muted font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
